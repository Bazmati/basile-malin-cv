---
import { basics } from "@cv";
import Vengeance from "@/layouts/Vengeance.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;

const { image, summary, url, theme } = basics;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={summary} />
		<meta name="viewport" content="width=device-width" />
		<meta name="google-site-verification" content="drvIVXmo2F0w9qjRiAN75xD5cwHgRZzuWq3hII8PxsQ" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preload" as="image" href={image} />

		<meta property="og:url" content={url} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={summary} />
		<meta property="og:image" content="" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:domain" content={url.split("//")[1] ?? ""} />
		<meta property="twitter:url" content={url} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={summary} />
		<meta name="twitter:image" content="" />

		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Itim" />

		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}themes/themes.css`} />
		<Vengeance />
	</head>
	<body data-theme={theme} class="relative bg-skin-fill">
		<div class="absolute top-0 -z-10 h-full w-full print:hidden">
			<div class="bg-skin-hue/10 absolute bottom-auto left-[20%] right-auto top-0 h-[200px] w-[200px] -translate-x-[30%] translate-y-[20%] rounded-full blur-[80px] invert-0 dark:bg-white/5"></div>
		</div>
		<slot />
		<style is:global>
			body,
			figure {
				margin: 0;
				padding: 0;
			}

			a {
				text-decoration: none;
			}

			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			h1,
			h2,
			h3,
			h4 {
				@apply text-skin-base;
				margin: 0;
				font-family:
					system-ui,
					-apple-system,
					BlinkMacSystemFont,
					"Segoe UI",
					Roboto,
					Oxygen,
					Ubuntu,
					Cantarell,
					"Open Sans",
					"Helvetica Neue",
					sans-serif;
			}

			p {
				@apply text-sm text-skin-muted;
				line-height: 1.5;
				text-wrap: pretty;
			}

			.print {
				display: none !important;
			}

			.dev * {
				@apply border border-red-500/50 bg-red-500/5;
			}
			#hotkeypad [data-backdrop] {
				@apply !bg-zinc-800 !opacity-80;
			}

			@media print {
				.no-print {
					display: none !important;
				}

				.print {
					display: block !important;
				}

				astro-dev-toolbar {
					display: none !important;
				}

				/* Améliorations optimisées pour l'impression */
				body {
					font-size: 12px; /* Taille de police optimisée pour la lisibilité */
					line-height: 1.3; /* Réduction de l'interligne pour économiser l'espace */
				}

				/* Éviter les coupures de sections importantes */
				article, section, .section {
					break-inside: avoid;
					page-break-inside: avoid;
				}

				/* Sauts de page intelligents pour les titres */
				h1, h2, h3, h4 {
					break-after: avoid;
					page-break-after: avoid;
					margin-bottom: 0.25rem !important; /* Réduction des marges */
				}

				/* Optimiser l'espacement pour impression - plus compact */
				.space-y-6 > * + * {
					margin-top: 0.5rem !important; /* Réduction de l'espacement */
				}

				.space-y-12 > * + * {
					margin-top: 0.75rem !important; /* Réduction de l'espacement */
				}

				/* Réduire les gaps pour gagner de l'espace */
				.gap-12 {
					gap: 0.75rem !important;
				}

				.gap-6 {
					gap: 0.5rem !important;
				}

				/* Optimiser la section Hero/About pour impression */
				.print .space-y-6 {
					margin-bottom: 0.5rem !important;
				}

				/* Réduire la taille des éléments dans Hero pour impression */
				.print .text-4xl {
					font-size: 1.5rem !important; /* Réduction de la taille du titre */
					line-height: 1.2 !important;
				}

				.print .text-xl {
					font-size: 1rem !important; /* Réduction de la taille du sous-titre */
				}

				/* Optimiser les paragraphes pour impression */
				.print p {
					margin-bottom: 0.25rem !important;
					line-height: 1.2 !important;
				}

				/* Masquer les éléments interactifs */
				button, .theme-switch, .keyboard-hints {
					display: none !important;
				}

				/* Grille adaptée pour impression */
				.print-grid-2 {
					display: grid !important;
					grid-template-columns: 1fr 1fr !important;
					gap: 0.75rem !important;
				}

				.print-grid-3 {
					display: grid !important;
					grid-template-columns: 1fr 1fr 1fr !important;
					gap: 0.5rem !important;
				}

				/* Forcer l'affichage des images */
				img {
					display: block !important;
					max-width: 100% !important;
					height: auto !important;
				}

				/* Optimiser les listes pour gagner de l'espace */
				ul, ol {
					margin: 0.25rem 0 !important;
					padding-left: 1rem !important;
				}

				li {
					margin-bottom: 0.125rem !important;
				}

				/* Réduire les padding des sections */
				.p-8 {
					padding: 0.5rem !important;
				}

				.py-16 {
					padding-top: 1rem !important;
					padding-bottom: 1rem !important;
				}
			}
		</style>
	</body>
</html>

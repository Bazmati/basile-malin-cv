---
import Layout from "@/layouts/Layout.astro";

import About from "@/components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import Tail from "@/components/sections/Tail.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

import { basics } from "@cv";
const { name, label } = basics;
---

<Layout title={`${name} curriculum vitae & Portafolio - ${label}`}>
	<main class="relative grid max-w-7xl gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:block print:space-y-8 print:p-0">
		<!-- Section Informations personnelles -->
		<div class="space-y-6 md:col-span-2 print:print-grid-2 print:gap-6 print:mb-8">
			<Hero />
			<About />
		</div>

		<!-- Section Expérience et Formation -->
		<div class="space-y-12 md:col-span-4 print:space-y-8">
			<Education className="print:mb-6" />
			<Experience className="print:print-grid-3 print:gap-4" />
		</div>

		<!-- Section Complémentaire (masquée en impression) -->
		<div class="md:col-span-6 print:hidden">
			<Projects />
			<Skills />
		</div>

		<Tail />
	</main>

	<KeyboardManager />
</Layout>

<style>
	@page {
		size: auto;
		margin: 0mm;
	}
	main {
		margin: auto;
		width: 100%;
	}
</style>
